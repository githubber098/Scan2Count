# ─────────────────────────────────────────────────────────────────────────────
# Sandbox environment variables for the test suite
#
# 1. Copy this file:  cp tests/.env.test.example tests/.env.test
# 2. Fill in your SANDBOX credentials (never the production ones)
# 3. .env.test is gitignored — never commit it
#
# Unit tests and mocked integration tests run fine WITHOUT this file.
# Only e2e tests (@pytest.mark.e2e) require real sandbox credentials.
# ─────────────────────────────────────────────────────────────────────────────

SUPABASE_URL=https://your-sandbox-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...sandbox-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...sandbox-service-role-key...

ANTHROPIC_API_KEY=sk-ant-api03-...sandbox-key...
GROQ_API_KEY=gsk_...sandbox-key...

# Keep this as "test" so secure cookies are never set during testing
ENVIRONMENT=test
